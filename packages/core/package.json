{
  "name": "@vuerend/core",
  "version": "0.2.0",
  "description": "Zero JavaScript-first Vue MPA runtime and Vite v8 plugin with SSR, SSG, and secure islands.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ubugeeei/vuerend"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./vite": {
      "types": "./dist/vite.d.mts",
      "import": "./dist/vite.mjs"
    },
    "./runtime": {
      "types": "./dist/runtime.d.mts",
      "import": "./dist/runtime.mjs"
    },
    "./client": {
      "types": "./dist/client.d.mts",
      "import": "./dist/client.mjs"
    },
    "./client/hydrate": {
      "types": "./dist/client/hydrate.d.mts",
      "import": "./dist/client/hydrate.mjs"
    },
    "./client/vapor-hydrate": {
      "types": "./dist/client/vapor-hydrate.d.mts",
      "import": "./dist/client/vapor-hydrate.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/server-renderer": "^3.5.31 || ^3.6.0-beta.10",
    "srvx": "^0.11.14"
  },
  "devDependencies": {
    "@vue/runtime-vapor": "3.6.0-beta.10",
    "vue": "3.6.0-beta.10"
  },
  "peerDependencies": {
    "@vue/runtime-vapor": "^3.6.0-beta.10",
    "vite": "^8.0.3",
    "vue": "^3.5.31 || ^3.6.0-beta.10"
  },
  "peerDependenciesMeta": {
    "@vue/runtime-vapor": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
