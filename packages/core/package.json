{
  "name": "@vuerend/core",
  "version": "0.1.1-alpha.2",
  "description": "Zero JavaScript-first Vue MPA runtime and Vite v8 plugin with SSR, SSG, and secure islands.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ubugeeei/vuerend"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./vite": {
      "types": "./dist/vite.d.mts",
      "import": "./dist/vite.mjs"
    },
    "./runtime": {
      "types": "./dist/runtime.d.mts",
      "import": "./dist/runtime.mjs"
    },
    "./client": {
      "types": "./dist/client.d.mts",
      "import": "./dist/client.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/server-renderer": "^3.5.31",
    "srvx": "^0.11.14"
  },
  "peerDependencies": {
    "vite": "^8.0.3",
    "vue": "^3.5.31"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
