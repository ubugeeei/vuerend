{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "ignoreDeprecations": "6.0",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "baseUrl": ".",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "useDefineForClassFields": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "paths": {
      "@vuerend/core": ["packages/core/src/index.ts"],
      "@vuerend/core/*": ["packages/core/src/*"],
      "@vuerend/node": ["packages/node/src/index.ts"],
      "@vuerend/cloudflare": ["packages/cloudflare/src/index.ts"],
      "@vuerend/service-worker": ["packages/service-worker/src/index.ts"],
      "@vuerend/bun": ["packages/bun/src/index.ts"],
      "@vuerend/deno": ["packages/deno/src/index.ts"]
    },
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "verbatimModuleSyntax": true
  },
  "include": ["env.d.ts", "examples", "vite.config.ts"],
  "exclude": ["dist", "node_modules", "packages/*/dist", "examples/*/dist"]
}
